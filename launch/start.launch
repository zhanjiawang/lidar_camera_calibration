<launch>
    <rosparam file="$(find lidar_camera_calibration)/config/params.yaml" command="load" />
    <node pkg="lidar_camera_calibration" type="lidar_camera_calibration" name="lidar_camera_calibration" output="screen" />
    <node pkg="rviz" type="rviz" name="rviz" args="-d $(find lidar_camera_calibration)/rviz/show.rviz" /> 
</launch>
